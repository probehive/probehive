root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[go.mod]
indent_style = tab
indent_size = 4
tab_width = 4

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_size = 2

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
